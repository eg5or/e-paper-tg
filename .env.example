# Telegram bot token for image processor bot
BOT_TOKEN=123456789:replace_with_real_token

# Target chat for sending processed .epd files
# Leave empty to send back to source chat
TARGET_CHAT_ID=

# Output image settings
TARGET_WIDTH=400
TARGET_HEIGHT=300
MAX_OUTPUT_BYTES=20000

# Use Telethon userbot for group delivery (optional)
USE_USERBOT_FOR_GROUP=false
USERBOT_API_ID=
USERBOT_API_HASH=
USERBOT_PHONE=
USERBOT_SESSION=userbot_session
